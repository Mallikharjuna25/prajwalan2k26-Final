<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MockPay Dashboard</title>
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="bg-light">

    <nav class="navbar navbar-expand-lg navbar-dark bg-primary mb-4">
        <div class="container">
            <a class="navbar-brand fw-bold" href="#">MockPay Admin</a>
        </div>
    </nav>

    <div class="container">
        <div class="card shadow-sm border-0 rounded-4">
            <div class="card-header bg-white border-bottom-0 pt-4 pb-0 px-4">
                <h4 class="fw-bold mb-0">Transaction History</h4>
                <p class="text-muted mb-3">All simulated payments captured by the local Mock Gateway.</p>
            </div>
            <div class="card-body px-4 pb-4">
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Transaction ID</th>
                                <th>Date</th>
                                <th>Registration ID</th>
                                <th>Student ID</th>
                                <th>Amount</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (payments.length===0) { %>
                                <tr>
                                    <td colspan="6" class="text-center py-4 text-muted">No transactions found.</td>
                                </tr>
                                <% } else { %>
                                    <% payments.forEach(function(payment) { %>
                                        <tr>
                                            <td><code class="text-dark"><%= payment.transactionId %></code></td>
                                            <td>
                                                <%= new Date(payment.date).toLocaleString() %>
                                            </td>
                                            <td><span class="text-truncate d-inline-block" style="max-width: 150px;">
                                                    <%= payment.registrationId %>
                                                </span></td>
                                            <td><span class="text-truncate d-inline-block" style="max-width: 150px;">
                                                    <%= payment.student %>
                                                </span></td>
                                            <td class="fw-bold">₹<%= payment.amount %>
                                            </td>
                                            <td>
                                                <% if (payment.status==='Success' ) { %>
                                                    <span class="badge bg-success">Success</span>
                                                    <% } else { %>
                                                        <span class="badge bg-danger">Failed</span>
                                                        <% } %>
                                            </td>
                                        </tr>
                                        <% }); %>
                                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

</body>

</html>