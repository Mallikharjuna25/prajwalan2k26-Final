<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Secure Payment Gateway | Mock</title>
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body {
            background-color: #f8f9fa;
        }

        .card {
            border: none;
            border-radius: 1rem;
            box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15);
        }

        .card-header {
            background-color: #0d6efd;
            color: white;
            border-radius: 1rem 1rem 0 0 !important;
            padding: 1.5rem;
        }

        .form-control:focus {
            box-shadow: none;
            border-color: #0d6efd;
        }

        #spinner-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(255, 255, 255, 0.9);
            z-index: 1050;
            display: none;
            flex-direction: column;
            justify-content: center;
            align-items: center;
        }
    </style>
</head>

<body>

    <div id="spinner-overlay">
        <div class="spinner-border text-primary" style="width: 3rem; height: 3rem;" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
        <h4 class="mt-3 text-primary">Processing Payment...</h4>
        <p class="text-muted">Please do not refresh the page.</p>
    </div>

    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-md-6 col-lg-5">
                <div class="text-center mb-4">
                    <h2 class="fw-bold text-primary">MockPay Gateway</h2>
                    <p class="text-muted">Sandbox Testing Environment</p>
                </div>

                <div class="card">
                    <div class="card-header text-center">
                        <h5 class="mb-0">Payment Summary</h5>
                    </div>
                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted">Event:</span>
                            <span class="fw-bold">
                                <%= eventTitle %>
                            </span>
                        </div>
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted">Participant:</span>
                            <span>
                                <%= studentName %>
                            </span>
                        </div>
                        <div class="d-flex justify-content-between mb-4 pb-3 border-bottom">
                            <span class="text-muted">Registration ID:</span>
                            <span class="text-truncate" style="max-width: 150px;">
                                <%= registrationId %>
                            </span>
                        </div>

                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <h4 class="mb-0 text-muted">Total Amount</h4>
                            <h3 class="mb-0 fw-bold text-success">₹<%= amount %>
                            </h3>
                        </div>

                        <form id="paymentForm" action="/api/payment/process/<%= registrationId %>" method="POST">
                            <input type="hidden" name="eventId" value="<%= eventId %>">
                            <input type="hidden" name="amount" value="<%= amount %>">
                            <input type="hidden" name="studentId" value="<%= studentId %>">

                            <div class="mb-3">
                                <label class="form-label text-muted small fw-bold">CARD NUMBER</label>
                                <input type="text" class="form-control form-control-lg"
                                    placeholder="1234 5678 9101 1121" required value="4000 0000 0000 0000">
                            </div>

                            <div class="row mb-4">
                                <div class="col-6">
                                    <label class="form-label text-muted small fw-bold">EXPIRY DATE (MM/YY)</label>
                                    <input type="text" class="form-control form-control-lg" placeholder="12/25" required
                                        value="12/26">
                                </div>
                                <div class="col-6">
                                    <label class="form-label text-muted small fw-bold">CVV</label>
                                    <input type="password" class="form-control form-control-lg" placeholder="123"
                                        required value="123">
                                </div>
                            </div>

                            <div class="mb-4">
                                <label class="form-label text-muted small fw-bold">CARDHOLDER NAME</label>
                                <input type="text" class="form-control form-control-lg" placeholder="Name on card"
                                    required value="<%= studentName %>">
                            </div>

                            <button type="submit" class="btn btn-primary btn-lg w-100 fw-bold">
                                Pay ₹<%= amount %> Now
                            </button>

                            <a href="http://localhost:5173/events/<%= eventId %>?canceled=true&registration_id=<%= registrationId %>"
                                class="btn btn-link w-100 mt-2 text-danger text-decoration-none">Cancel Payment</a>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.getElementById('paymentForm').addEventListener('submit', function (e) {
            e.preventDefault();
            // Show overlay spinner
            document.getElementById('spinner-overlay').style.display = 'flex';

            // Simulate 2 second loading delay before actually submitting the form to backend
            setTimeout(() => {
                this.submit();
            }, 2000);
        });
    </script>
</body>

</html>